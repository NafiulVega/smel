## Kode ESP32 — Final (WiFi + NTP + API, Target < 5 Detik/Siklus)

### Library yang Digunakan:
- `WiFi.h` — koneksi WiFi
- `HTTPClient.h` — HTTP GET/POST
- `ArduinoJson.h` — parse dan serialize JSON (v6+)
- `PZEM004Tv30.h` — komunikasi sensor PZEM-004T
- `time.h` — NTP sync dan timestamp

### Kode C++ Lengkap:

```cpp
#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <PZEM004Tv30.h>
#include <time.h>

// ============================================================
//  KONFIGURASI — Sesuaikan bagian ini
// ============================================================
const char* WIFI_SSID      = "NAMA_WIFI_ANDA";
const char* WIFI_PASSWORD  = "PASSWORD_WIFI_ANDA";
const char* SERVER_IP      = "192.168.1.100";   // IP server Django
const int   SERVER_PORT    = 8000;
const int   HTTP_TIMEOUT   = 2000;              // ms — timeout HTTP (jaringan lokal)

// Interval GET relay-status: setiap N siklus sensor
// Satu siklus ~3-4 detik → N=10 berarti GET setiap ~30-40 detik
const int   RELAY_POLL_EVERY_N_CYCLES = 10;

// NTP — WIB (UTC+7)
const char* NTP_SERVER  = "pool.ntp.org";
const long  GMT_OFFSET  = 25200;   // 7 × 3600
const int   DST_OFFSET  = 0;

// ============================================================
//  HARDWARE
// ============================================================
#define NUM_CHANNELS 2
const int relayPins[NUM_CHANNELS] = {13, 12};

// Status relay — fallback jika server tidak bisa dihubungi
bool relayState[NUM_CHANNELS] = {false, false};

// PZEM Channel 1 — UART2, RX=16, TX=17
HardwareSerial SerialPZEM1(2);
PZEM004Tv30   pzem1(SerialPZEM1, 16, 17, 0x10);

// PZEM Channel 2 — UART1, RX=4, TX=5
HardwareSerial SerialPZEM2(1);
PZEM004Tv30   pzem2(SerialPZEM2, 4, 5, 0x10);

// ============================================================
//  STRUKTUR DATA
// ============================================================
struct SensorReading {
    bool  relay_on;
    bool  sensor_ok;
    float voltage, current, power, energy, frequency, pf;
};

// ============================================================
//  UTILITY
// ============================================================
String getTimestamp() {
    struct tm t;
    if (!getLocalTime(&t)) return "1970-01-01T00:00:00";
    char buf[20];
    strftime(buf, sizeof(buf), "%Y-%m-%dT%H:%M:%S", &t);
    return String(buf);
}

void connectWiFi() {
    if (WiFi.status() == WL_CONNECTED) return;
    Serial.printf("Menghubungkan ke WiFi: %s", WIFI_SSID);
    WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
    for (int i = 0; i < 20 && WiFi.status() != WL_CONNECTED; i++) {
        delay(500);
        Serial.print(".");
    }
    Serial.println(WiFi.status() == WL_CONNECTED
        ? "\nWiFi OK: " + WiFi.localIP().toString()
        : "\nWiFi GAGAL — mode offline.");
}

// ============================================================
//  API: GET /api/relay-status
// ============================================================
bool fetchRelayStatus() {
    if (WiFi.status() != WL_CONNECTED) return false;

    HTTPClient http;
    String url = "http://" + String(SERVER_IP) + ":" + SERVER_PORT + "/api/relay-status";
    http.begin(url);
    http.setTimeout(HTTP_TIMEOUT);
    int code = http.GET();

    if (code != 200) {
        Serial.printf("[GET] Gagal HTTP %d\n", code);
        http.end();
        return false;
    }

    StaticJsonDocument<512> doc;
    if (deserializeJson(doc, http.getString()) != DeserializationError::Ok) {
        Serial.println("[GET] JSON parse error");
        http.end();
        return false;
    }
    http.end();

    for (JsonObject ch : doc["channels"].as<JsonArray>()) {
        int idx = ch["channel"].as<int>() - 1;  // 0-based
        if (idx < 0 || idx >= NUM_CHANNELS) continue;
        relayState[idx] = ch["relay_on"].as<bool>();
        digitalWrite(relayPins[idx], relayState[idx] ? HIGH : LOW);
        Serial.printf("[RELAY] Ch%d (pin%d): %s\n",
                      idx+1, relayPins[idx], relayState[idx] ? "ON" : "OFF");
    }
    return true;
}

// ============================================================
//  BACA SENSOR PZEM
// ============================================================
SensorReading readChannel(PZEM004Tv30 &pzem, bool relayOn) {
    SensorReading r{};
    r.relay_on = relayOn;
    if (!relayOn) return r;  // relay OFF: semua false/0, tidak baca

    float v = pzem.voltage();
    if (isnan(v)) {
        r.sensor_ok = false;  // gagal baca → notifikasi di server
        return r;
    }

    r.sensor_ok  = true;
    r.voltage    = v;
    r.current    = pzem.current();
    r.power      = pzem.power();
    r.energy     = pzem.energy();
    r.frequency  = pzem.frequency();
    r.pf         = pzem.pf();
    return r;
}

// ============================================================
//  API: POST /api/sensor-data
// ============================================================
bool sendSensorData(SensorReading readings[]) {
    if (WiFi.status() != WL_CONNECTED) return false;

    const char* uartLabels[NUM_CHANNELS] = {"UART2", "UART1"};

    StaticJsonDocument<1024> doc;
    doc["timestamp"]   = getTimestamp();
    JsonArray arr      = doc.createNestedArray("readings");

    for (int i = 0; i < NUM_CHANNELS; i++) {
        JsonObject obj  = arr.createNestedObject();
        obj["channel"]  = i + 1;
        obj["address"]  = "0x10";
        obj["uart"]     = uartLabels[i];
        obj["relay_on"] = readings[i].relay_on;
        obj["sensor_ok"]= readings[i].sensor_ok;

        if (readings[i].sensor_ok) {
            obj["voltage"]   = serialized(String(readings[i].voltage,   1));
            obj["current"]   = serialized(String(readings[i].current,   3));
            obj["power"]     = serialized(String(readings[i].power,     1));
            obj["energy"]    = serialized(String(readings[i].energy,    3));
            obj["frequency"] = serialized(String(readings[i].frequency, 1));
            obj["pf"]        = serialized(String(readings[i].pf,        2));
        } else {
            obj["voltage"] = obj["current"] = obj["power"] =
            obj["energy"]  = obj["frequency"] = obj["pf"] = nullptr;
        }
    }

    String body;
    serializeJson(doc, body);

    HTTPClient http;
    String url = "http://" + String(SERVER_IP) + ":" + SERVER_PORT + "/api/sensor-data";
    http.begin(url);
    http.setTimeout(HTTP_TIMEOUT);
    http.addHeader("Content-Type", "application/json");
    int code = http.POST(body);

    bool ok = (code == 200);
    if (ok) Serial.println("[POST] Terkirim: " + http.getString());
    else    Serial.printf("[POST] Gagal HTTP %d\n", code);
    http.end();
    return ok;
}

// ============================================================
//  SETUP
// ============================================================
void setup() {
    Serial.begin(115200);

    // Relay OFF saat boot (aman)
    for (int i = 0; i < NUM_CHANNELS; i++) {
        pinMode(relayPins[i], OUTPUT);
        digitalWrite(relayPins[i], LOW);
    }

    connectWiFi();
    configTime(GMT_OFFSET, DST_OFFSET, NTP_SERVER);

    // Tunggu NTP sync
    Serial.print("Sinkronisasi NTP");
    for (int i = 0; i < 10; i++) {
        struct tm t;
        if (getLocalTime(&t)) { Serial.println(" OK"); break; }
        delay(500); Serial.print(".");
    }
    Serial.println("Timestamp: " + getTimestamp());

    // GET relay-status pertama kali saat boot
    fetchRelayStatus();
}

// ============================================================
//  LOOP — Target < 5 detik per siklus
// ============================================================
void loop() {
    static int cycleCount = 0;
    unsigned long cycleStart = millis();

    // Reconnect WiFi jika putus
    if (WiFi.status() != WL_CONNECTED) connectWiFi();

    // GET relay-status setiap N siklus (tidak perlu setiap siklus)
    if (cycleCount % RELAY_POLL_EVERY_N_CYCLES == 0) {
        Serial.println("--- [GET] Relay Status ---");
        fetchRelayStatus();
    }

    // Optimasi: jika SEMUA relay OFF (di luar jam nyala),
    // skip baca sensor dan POST — hemat waktu dan bandwidth
    bool anyRelayOn = false;
    for (int i = 0; i < NUM_CHANNELS; i++)
        if (relayState[i]) { anyRelayOn = true; break; }

    if (anyRelayOn) {
        // Baca sensor hanya channel yang relay-nya ON
        Serial.println("--- [PZEM] Baca Sensor ---");
        SensorReading readings[NUM_CHANNELS];
        readings[0] = readChannel(pzem1, relayState[0]);
        readings[1] = readChannel(pzem2, relayState[1]);

        for (int i = 0; i < NUM_CHANNELS; i++) {
            Serial.printf("Ch%d: relay=%s sensor=%s", i+1,
                readings[i].relay_on ? "ON" : "OFF",
                readings[i].sensor_ok ? "OK" : "FAIL/OFF");
            if (readings[i].sensor_ok)
                Serial.printf(" V=%.1f A=%.3f W=%.1f kWh=%.3f Hz=%.1f PF=%.2f",
                    readings[i].voltage, readings[i].current, readings[i].power,
                    readings[i].energy,  readings[i].frequency, readings[i].pf);
            Serial.println();
        }

        // POST ke server → server akan broadcast ke WebSocket dashboard
        Serial.println("--- [POST] Kirim Data ---");
        sendSensorData(readings);
    } else {
        Serial.println("--- Semua relay OFF, skip baca sensor ---");
    }

    cycleCount++;
    unsigned long elapsed = millis() - cycleStart;
    Serial.printf("=== Siklus #%d selesai dalam %lu ms ===\n\n", cycleCount, elapsed);

    // Tidak ada delay() besar di sini — kecepatan siklus ditentukan
    // oleh waktu PZEM + HTTP saja (~3-4 detik, sudah < 5 detik)
    // Tambahkan delay kecil hanya untuk stabilitas
    delay(500);
}
